# =============================================================================
# MONKEYSCLOUD — LOCAL DEVELOPMENT ENVIRONMENT
# =============================================================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
# =============================================================================

# --- General ------------------------------------------------------------------
APP_NAME=MonkeysCloud
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=80

# --- API (MonkeysLegion) -----------------------------------------------------
API_PORT=8000
API_WORKERS=4
API_LOG_LEVEL=debug

# --- Dashboard (Next.js) -----------------------------------------------------
DASHBOARD_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GIT_URL=http://localhost:3001

# --- Git Server ---------------------------------------------------------------
GIT_PORT=3001
GIT_REPOS_PATH=/var/lib/git

# --- MySQL --------------------------------------------------------------------
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=monkeyscloud
MYSQL_USER=monkeyscloud
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=rootsecret

# --- Redis --------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- MinIO (S3-compatible local storage) --------------------------------------
MINIO_ROOT_USER=monkeyscloud
MINIO_ROOT_PASSWORD=miniosecret
MINIO_ENDPOINT=http://minio:9000
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_REPOS=mc-git-repos
MINIO_BUCKET_ARTIFACTS=mc-build-artifacts
MINIO_BUCKET_ASSETS=mc-assets
MINIO_BUCKET_BACKUPS=mc-backups

# --- Mail (Mailpit) ----------------------------------------------------------
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS=no-reply@monkeys.cloud
MAIL_FROM_NAME=MonkeysCloud
MAILPIT_UI_PORT=8025

# --- JWT / Auth ---------------------------------------------------------------
JWT_SECRET=change-me-in-production-use-64-char-random-string
JWT_TTL=3600
JWT_REFRESH_TTL=604800

# --- CI/CD Worker -------------------------------------------------------------
CICD_WORKER_CONCURRENCY=2
DOCKER_HOST=unix:///var/run/docker.sock
REGISTRY_URL=http://registry:5000

# --- Local Docker Registry ---------------------------------------------------
REGISTRY_PORT=5000

# --- Nginx --------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
